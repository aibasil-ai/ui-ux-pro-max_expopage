---
import type { ProductCategoryGroup } from '../../lib/product-taxonomy';

interface Props {
  categories: ProductCategoryGroup[];
}

const { categories } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
  {categories.map((category) => (
    <article class="rounded-3xl border border-slate-200 bg-white/90 p-5 shadow-sm shadow-slate-950/5">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-indigo-600">{category.name}</p>
      <h2 class="mt-3 text-lg font-semibold text-slate-950">{category.products.length} 種產品細類</h2>
      <p class="mt-3 text-sm leading-6 text-slate-600">{category.description}</p>
      <p class="mt-4 text-sm leading-6 text-slate-500">{category.highlight}</p>
    </article>
  ))}
</div>
