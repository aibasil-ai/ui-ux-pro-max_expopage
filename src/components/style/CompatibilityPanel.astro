---
import type { StyleRecord } from '../../lib/content/get-styles';

interface Props {
  style: StyleRecord;
  accentMode: string;
}

const { style, accentMode } = Astro.props;
const accentMap: Record<string, string> = {
  indigo: 'bg-indigo-50 text-indigo-700 border-indigo-200',
  cyan: 'bg-cyan-50 text-cyan-700 border-cyan-200',
  emerald: 'bg-emerald-50 text-emerald-700 border-emerald-200',
  fuchsia: 'bg-fuchsia-50 text-fuchsia-700 border-fuchsia-200',
  amber: 'bg-amber-50 text-amber-700 border-amber-200',
  mono: 'bg-slate-100 text-slate-700 border-slate-200',
  crimson: 'bg-rose-50 text-rose-700 border-rose-200'
};
const accentClass = accentMap[accentMode] ?? accentMap.indigo;
---

<section class="rounded-[2rem] border border-slate-200 bg-white/95 p-6 shadow-sm shadow-slate-950/5">
  <div class="flex flex-wrap items-center gap-3">
    <span class={`rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] ${accentClass}`}>
      {style.category}
    </span>
    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">{style.raw['Performance']}</span>
    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">{style.raw['Accessibility']}</span>
  </div>

  <div class="mt-5 grid gap-5 md:grid-cols-2">
    <div>
      <h3 class="text-lg font-semibold text-slate-950">適合場景</h3>
      <p class="mt-2 text-sm leading-7 text-slate-600">{style.summary}</p>
    </div>
    <div>
      <h3 class="text-lg font-semibold text-slate-950">避免使用</h3>
      <p class="mt-2 text-sm leading-7 text-slate-600">{style.raw['Do Not Use For'] || '避免把風格張力放在錯誤的產品脈絡。'}</p>
    </div>
  </div>
</section>
