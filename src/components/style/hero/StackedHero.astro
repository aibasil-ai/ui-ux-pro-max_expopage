---
import type { StyleRecord } from '../../../lib/content/get-styles';
import type { StyleManifest } from '../../../lib/style-manifests/types';
interface Props { style: StyleRecord; manifest: StyleManifest; }
const { style, manifest } = Astro.props;
---
<section class="rounded-[2.5rem] border border-slate-200 bg-white/90 p-8 shadow-sm shadow-slate-950/5">
  <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">{manifest.heroKicker}</p>
  <h1 class="mt-4 text-5xl font-semibold tracking-tight text-slate-950 md:text-6xl">{style.title}</h1>
  <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">{manifest.perspective}</p>
  <div class="mt-8 grid gap-4 md:grid-cols-3">
    <div class="rounded-[1.5rem] bg-slate-100 p-4 text-sm leading-7 text-slate-700">{manifest.moodLine}</div>
    <div class="rounded-[1.5rem] bg-slate-100 p-4 text-sm leading-7 text-slate-700">{style.raw['Era/Origin']}</div>
    <div class="rounded-[1.5rem] bg-slate-950 p-4 text-sm leading-7 text-slate-100">{style.raw['Complexity']}</div>
  </div>
</section>
