---
import type { StyleRecord } from '../../../lib/content/get-styles';
import type { StyleManifest } from '../../../lib/style-manifests/types';
import { buildStyleShowcaseTheme } from '../../../lib/style-showcase-theme';
interface Props { style: StyleRecord; manifest: StyleManifest; }
const { style, manifest } = Astro.props;
const theme = buildStyleShowcaseTheme(style, manifest);
---
<section class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr] xl:items-center">
  <div>
    <p class="text-sm font-semibold uppercase tracking-[0.22em]" style="color:var(--ss-muted);">{manifest.heroKicker}</p>
    <h1 class="mt-4 text-5xl font-semibold tracking-tight md:text-6xl" style="color:var(--ss-text);">{style.title}</h1>
    <p class="mt-5 max-w-2xl text-lg leading-8" style="color:var(--ss-muted);">{manifest.perspective}</p>
  </div>
  <div class="grid gap-4 md:grid-cols-3">
    <div class={`rounded-[1.75rem] border p-5 ${theme.motionClass}`} style="border-color:var(--ss-border);background:var(--ss-panel);"><p class="text-xs" style="color:var(--ss-muted);">Performance</p><p class="mt-2 text-3xl font-semibold" style="color:var(--ss-text);">{style.raw['Performance']}</p></div>
    <div class={`rounded-[1.75rem] border p-5 ${theme.motionClass}`} style="border-color:var(--ss-border);background:var(--ss-panel);"><p class="text-xs" style="color:var(--ss-muted);">Accessibility</p><p class="mt-2 text-3xl font-semibold" style="color:var(--ss-text);">{style.raw['Accessibility']}</p></div>
    <div class={`rounded-[1.75rem] border p-5 ${theme.motionClass}`} style="border-color:var(--ss-border);background:var(--ss-panel);"><p class="text-xs" style="color:var(--ss-muted);">Complexity</p><p class="mt-2 text-3xl font-semibold" style="color:var(--ss-text);">{style.raw['Complexity']}</p></div>
  </div>
</section>
