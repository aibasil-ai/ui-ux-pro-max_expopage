---
import type { StyleRecord } from '../../../lib/content/get-styles';
import type { StyleManifest } from '../../../lib/style-manifests/types';
interface Props { style: StyleRecord; manifest: StyleManifest; }
const { style, manifest } = Astro.props;
---
<section class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr] xl:items-center">
  <div>
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">{manifest.heroKicker}</p>
    <h1 class="mt-4 text-5xl font-semibold tracking-tight text-slate-950 md:text-6xl">{style.title}</h1>
    <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-600">{manifest.perspective}</p>
  </div>
  <div class="grid gap-4 md:grid-cols-3">
    <div class="rounded-[1.75rem] border border-slate-200 bg-white p-5"><p class="text-xs text-slate-500">Performance</p><p class="mt-2 text-3xl font-semibold text-slate-950">{style.raw['Performance']}</p></div>
    <div class="rounded-[1.75rem] border border-slate-200 bg-white p-5"><p class="text-xs text-slate-500">Accessibility</p><p class="mt-2 text-3xl font-semibold text-slate-950">{style.raw['Accessibility']}</p></div>
    <div class="rounded-[1.75rem] border border-slate-200 bg-white p-5"><p class="text-xs text-slate-500">Complexity</p><p class="mt-2 text-3xl font-semibold text-slate-950">{style.raw['Complexity']}</p></div>
  </div>
</section>
