---
import type { StyleRecord } from '../../../lib/content/get-styles';
import type { StyleManifest } from '../../../lib/style-manifests/types';
import { buildStyleShowcaseTheme } from '../../../lib/style-showcase-theme';

interface Props {
  style: StyleRecord;
  manifest: StyleManifest;
}

const { style, manifest } = Astro.props;
const theme = buildStyleShowcaseTheme(style, manifest);
---

<section class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr] xl:items-end">
  <div class="space-y-5">
    <p class="text-sm font-semibold uppercase tracking-[0.22em]" style="color:var(--ss-muted);">{manifest.heroKicker}</p>
    <h1 class="max-w-4xl text-5xl font-semibold tracking-tight md:text-6xl" style="color:var(--ss-text);">{style.title}</h1>
    <p class="max-w-2xl text-lg leading-8" style="color:var(--ss-muted);">{manifest.perspective}</p>
  </div>
  <div
    class={`rounded-[2rem] border p-6 shadow-sm ${theme.motionClass}`}
    style="border-color:var(--ss-border);background:var(--ss-panel);box-shadow:0 14px 24px -24px var(--ss-accent);"
  >
    <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color:var(--ss-muted);">Mood Line</p>
    <p class="mt-3 text-base leading-7" style="color:var(--ss-text);">{manifest.moodLine}</p>
  </div>
</section>
