---
import type { StyleRecord } from '../../../lib/content/get-styles';
import type { StyleManifest } from '../../../lib/style-manifests/types';

interface Props {
  style: StyleRecord;
  manifest: StyleManifest;
}

const { style, manifest } = Astro.props;
---

<section class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr] xl:items-end">
  <div class="space-y-5">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">{manifest.heroKicker}</p>
    <h1 class="max-w-4xl text-5xl font-semibold tracking-tight text-slate-950 md:text-6xl">{style.title}</h1>
    <p class="max-w-2xl text-lg leading-8 text-slate-600">{manifest.perspective}</p>
  </div>
  <div class="rounded-[2rem] border border-slate-200 bg-white/90 p-6 shadow-sm shadow-slate-950/5">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Mood Line</p>
    <p class="mt-3 text-base leading-7 text-slate-700">{manifest.moodLine}</p>
  </div>
</section>
