---
import type { StyleRecord } from '../../../lib/content/get-styles';
import type { StyleManifest } from '../../../lib/style-manifests/types';
import BrutalismBadge from '../previews/style-specific/BrutalismBadge.astro';
interface Props { style: StyleRecord; manifest: StyleManifest; }
const { style, manifest } = Astro.props;
---
<section class="grid gap-6 rounded-[2.5rem] border border-slate-950 bg-white p-8 shadow-[12px_12px_0_rgba(15,23,42,0.08)] xl:grid-cols-[0.9fr_1.1fr]">
  <div class="space-y-4">
    <p class="text-sm font-black uppercase tracking-[0.24em] text-slate-500">{manifest.heroKicker}</p>
    <BrutalismBadge />
  </div>
  <div>
    <h1 class="text-5xl font-black uppercase tracking-[-0.04em] text-slate-950 md:text-6xl">{style.title}</h1>
    <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-700">{manifest.perspective}</p>
  </div>
</section>
