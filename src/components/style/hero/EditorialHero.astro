---
import type { StyleRecord } from '../../../lib/content/get-styles';
import type { StyleManifest } from '../../../lib/style-manifests/types';
import { buildStyleShowcaseTheme } from '../../../lib/style-showcase-theme';
import BrutalismBadge from '../previews/style-specific/BrutalismBadge.astro';
interface Props { style: StyleRecord; manifest: StyleManifest; }
const { style, manifest } = Astro.props;
const theme = buildStyleShowcaseTheme(style, manifest);
---
<section
  class={`grid gap-6 rounded-[2.5rem] border p-8 xl:grid-cols-[0.9fr_1.1fr] ${theme.motionClass}`}
  style="border-color:var(--ss-border);background:var(--ss-panel);box-shadow:12px 12px 0 color-mix(in srgb,var(--ss-accent) 26%, transparent);"
>
  <div class="space-y-4">
    <p class="text-sm font-black uppercase tracking-[0.24em]" style="color:var(--ss-muted);">{manifest.heroKicker}</p>
    <BrutalismBadge />
  </div>
  <div>
    <h1 class="text-5xl font-black uppercase tracking-[-0.04em] md:text-6xl" style="color:var(--ss-text);">{style.title}</h1>
    <p class="mt-5 max-w-2xl text-lg leading-8" style="color:var(--ss-muted);">{manifest.perspective}</p>
  </div>
</section>
