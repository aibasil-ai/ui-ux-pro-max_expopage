---
import type { StyleRecord } from '../../../lib/content/get-styles';
import type { StyleManifest } from '../../../lib/style-manifests/types';
import { buildStyleShowcaseTheme } from '../../../lib/style-showcase-theme';
interface Props { style: StyleRecord; manifest: StyleManifest; }
const { style, manifest } = Astro.props;
const theme = buildStyleShowcaseTheme(style, manifest);
---
<section
  class={`overflow-hidden rounded-[2.75rem] border p-8 text-white shadow-sm ${theme.motionClass}`}
  style="border-color:var(--ss-border);background:linear-gradient(140deg,var(--ss-bg-from),var(--ss-bg-to));"
>
  <div class="relative">
    <div class="absolute -left-20 -top-20 h-64 w-64 rounded-full blur-3xl" style="background:color-mix(in srgb,var(--ss-accent) 45%, transparent);"></div>
    <div class="absolute right-0 top-10 h-48 w-48 rounded-full blur-3xl" style="background:color-mix(in srgb,var(--ss-accent-2) 35%, transparent);"></div>
    <div class="relative grid gap-6 xl:grid-cols-[1.1fr_0.9fr] xl:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-white/70">{manifest.heroKicker}</p>
        <h1 class="mt-4 text-5xl font-semibold tracking-tight md:text-6xl">{style.title}</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/75">{manifest.perspective}</p>
      </div>
      <div class="rounded-[1.75rem] border p-6 backdrop-blur-xl" style="border-color:color-mix(in srgb,var(--ss-accent) 30%, white);background:color-mix(in srgb,var(--ss-panel) 45%, transparent);">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-white/60">Mood Line</p>
        <p class="mt-3 text-sm leading-7 text-white/80">{manifest.moodLine}</p>
      </div>
    </div>
  </div>
</section>
