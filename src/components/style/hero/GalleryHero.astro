---
import type { StyleRecord } from '../../../lib/content/get-styles';
import type { StyleManifest } from '../../../lib/style-manifests/types';
interface Props { style: StyleRecord; manifest: StyleManifest; }
const { style, manifest } = Astro.props;
---
<section class="space-y-6">
  <div>
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">{manifest.heroKicker}</p>
    <h1 class="mt-4 text-5xl font-semibold tracking-tight text-slate-950 md:text-6xl">{style.title}</h1>
  </div>
  <div class="grid gap-4 md:grid-cols-3">
    <div class="rounded-[1.75rem] border border-slate-200 bg-white/80 p-6 md:col-span-2">
      <p class="text-base leading-8 text-slate-600">{manifest.perspective}</p>
    </div>
    <div class="rounded-[1.75rem] border border-slate-200 bg-slate-950 p-6 text-white">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Mood</p>
      <p class="mt-3 text-sm leading-7 text-slate-200">{manifest.moodLine}</p>
    </div>
  </div>
</section>
