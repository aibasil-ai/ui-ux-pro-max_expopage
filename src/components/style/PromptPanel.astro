---
interface Props {
  title: string;
  prompt: string;
  keywords?: string;
}

const { title, prompt, keywords = '' } = Astro.props;
---

<section class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-slate-100 shadow-sm shadow-slate-950/10">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Prompt Formula</p>
      <h3 class="mt-2 text-2xl font-semibold">用這段描述 {title}</h3>
    </div>
    <button
      type="button"
      class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-white transition hover:-translate-y-0.5"
      onclick={`navigator.clipboard.writeText(${JSON.stringify(prompt)})`}
    >
      複製文字
    </button>
  </div>
  {keywords && <p class="mt-4 text-sm leading-7 text-slate-300">關鍵提示：{keywords}</p>}
  <pre class="mt-5 whitespace-pre-wrap text-sm leading-7 text-slate-200">{prompt}</pre>
</section>
