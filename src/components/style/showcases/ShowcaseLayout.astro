---
import { buildStyleShowcaseTheme } from '../../../lib/style-showcase-theme';

interface Props {
  title?: string;
  description?: string;
  style?: { slug?: string; raw?: Record<string, string | undefined> };
  manifest?: { accentMode?: 'indigo' | 'cyan' | 'emerald' | 'fuchsia' | 'amber' | 'mono' | 'crimson' };
}

const { title, description, style, manifest } = Astro.props;
const theme = buildStyleShowcaseTheme(style ?? { slug: 'default-showcase', raw: {} }, manifest);
---

<section class={`space-y-6 ${theme.fontClass}`} style={theme.rootStyle} data-showcase-theme>
  {title ? (
    <div class="space-y-2">
      <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color:var(--ss-muted);">Showcase Layout</p>
      <h2 class="text-2xl font-semibold" style="color:var(--ss-text);">{title}</h2>
      {description ? <p class="text-sm leading-7" style="color:var(--ss-muted);">{description}</p> : null}
    </div>
  ) : null}
  <div
    class={`rounded-[2.25rem] border p-4 md:p-6 ${theme.motionClass}`}
    style="border-color:var(--ss-border);background:linear-gradient(145deg,var(--ss-bg-from),var(--ss-bg-to));"
  >
    <slot />
  </div>
</section>
