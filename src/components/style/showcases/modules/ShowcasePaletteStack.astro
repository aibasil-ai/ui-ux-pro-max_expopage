---
import { buildStyleShowcaseTheme } from '../../../../lib/style-showcase-theme';

const { style } = Astro.props;
const raw = style && style.raw ? style.raw : {};
const theme = buildStyleShowcaseTheme(style ?? { slug: 'default-showcase', raw: {} });
const primary = raw['Primary Colors'] || 'Primary palette';
const secondary = raw['Secondary Colors'] || 'Secondary palette';
---

<div class={`border p-6 ${theme.motionClass}`} style="border-width:var(--ss-border-width);border-radius:var(--ss-radius-panel);border-color:var(--ss-border);background:var(--ss-panel);">
  <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color:var(--ss-muted);">Palette Stack</p>
  <div class="mt-4 grid gap-4 md:grid-cols-2">
    <div class="border p-4" style="border-width:var(--ss-border-width);border-radius:var(--ss-radius-card);border-color:var(--ss-border);background:linear-gradient(135deg,var(--ss-panel-soft),var(--ss-bg-from));">
      <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color:var(--ss-muted);">Primary</p>
      <p class="mt-2 text-sm" style="color:var(--ss-text);">{primary}</p>
    </div>
    <div class="border p-4" style="border-width:var(--ss-border-width);border-radius:var(--ss-radius-card);border-color:var(--ss-border);background:linear-gradient(135deg,var(--ss-panel-soft),var(--ss-bg-to));">
      <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color:var(--ss-muted);">Secondary</p>
      <p class="mt-2 text-sm" style="color:var(--ss-text);">{secondary}</p>
    </div>
  </div>
</div>
