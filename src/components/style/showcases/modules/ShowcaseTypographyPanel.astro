---
import { buildStyleShowcaseTheme } from '../../../../lib/style-showcase-theme';

const { style, manifest, relatedTypography } = Astro.props;
const title = relatedTypography && relatedTypography.title ? relatedTypography.title : 'Typography Pair';
const heading = relatedTypography && relatedTypography.raw ? relatedTypography.raw['Heading Font'] : '';
const body = relatedTypography && relatedTypography.raw ? relatedTypography.raw['Body Font'] : '';
const theme = buildStyleShowcaseTheme(style ?? { slug: 'default-showcase', raw: {} }, manifest);
---

<div class={`border p-6 ${theme.motionClass}`} style="border-width:var(--ss-border-width);border-radius:var(--ss-radius-panel);border-color:var(--ss-border);background:var(--ss-panel);">
  <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color:var(--ss-muted);">Typography</p>
  <h3 class={`mt-3 text-2xl font-semibold ${theme.fontClass}`} style="color:var(--ss-text);">{title}</h3>
  <div class="mt-4 grid gap-3 md:grid-cols-2">
    <div class="border p-4" style="border-width:var(--ss-border-width);border-radius:var(--ss-radius-card);border-color:var(--ss-border);background:var(--ss-panel-soft);">
      <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color:var(--ss-muted);">Heading</p>
      <p class={`mt-2 text-sm ${theme.fontClass}`} style="color:var(--ss-text);">{heading || 'Heading Font'}</p>
    </div>
    <div class="border p-4" style="border-width:var(--ss-border-width);border-radius:var(--ss-radius-card);border-color:var(--ss-border);background:var(--ss-panel-soft);">
      <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color:var(--ss-muted);">Body</p>
      <p class="mt-2 text-sm" style="color:var(--ss-text);">{body || 'Body Font'}</p>
    </div>
  </div>
</div>
