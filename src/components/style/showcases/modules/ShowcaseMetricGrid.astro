---
import { buildStyleShowcaseTheme } from '../../../../lib/style-showcase-theme';

const { style } = Astro.props;
const raw = style && style.raw ? style.raw : {};
const theme = buildStyleShowcaseTheme(style ?? { slug: 'default-showcase', raw: {} });
const metrics = [
  { label: 'Performance', value: raw['Performance'] || 'A' },
  { label: 'Accessibility', value: raw['Accessibility'] || 'A-' },
  { label: 'Complexity', value: raw['Complexity'] || 'Medium' }
];
---

<div class="grid gap-4 md:grid-cols-3">
  {metrics.map((metric) => (
    <div
      class={`border p-5 ${theme.motionClass}`}
      style="border-width:var(--ss-border-width);border-radius:var(--ss-radius-card);border-color:var(--ss-border);background:var(--ss-panel);"
    >
      <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color:var(--ss-muted);">{metric.label}</p>
      <p class="mt-3 text-3xl font-semibold" style="color:var(--ss-text);">{metric.value}</p>
    </div>
  ))}
</div>
