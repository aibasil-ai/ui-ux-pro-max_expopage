---
import { buildStyleShowcaseTheme } from '../../../../lib/style-showcase-theme';

const { style } = Astro.props;
const raw = style && style.raw ? style.raw : {};
const theme = buildStyleShowcaseTheme(style ?? { slug: 'default-showcase', raw: {} });
const cards = [
  { label: 'Best For', value: raw['Best For'] || 'Product fit' },
  { label: 'Keywords', value: raw['Keywords'] || 'Keywords' },
  { label: 'Effects', value: raw['Effects & Animation'] || 'Visual motion' }
];
---

<div class="grid gap-4 md:grid-cols-3">
  {cards.map((card) => (
    <div
      class={`rounded-[1.5rem] border p-5 shadow-sm ${theme.motionClass}`}
      style="border-color:var(--ss-border);background:var(--ss-panel-soft);box-shadow:0 12px 26px -24px var(--ss-accent);"
    >
      <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color:var(--ss-muted);">{card.label}</p>
      <p class="mt-3 text-sm leading-7" style="color:var(--ss-text);">{card.value}</p>
    </div>
  ))}
</div>
