---
import type { StyleRecord } from '../../../lib/content/get-styles';
interface Props { style: StyleRecord; }
const { style } = Astro.props;
---
<section class="rounded-[2rem] border border-slate-200 bg-white/95 p-6 shadow-sm shadow-slate-950/5">
  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Visual DNA</p>
  <h2 class="mt-3 text-2xl font-semibold text-slate-950">視覺構成</h2>
  <div class="mt-5 grid gap-4 md:grid-cols-2">
    <div class="rounded-[1.5rem] bg-slate-50 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Primary Colors</p>
      <p class="mt-3 text-sm leading-7 text-slate-700">{style.raw['Primary Colors']}</p>
    </div>
    <div class="rounded-[1.5rem] bg-slate-50 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Secondary Colors</p>
      <p class="mt-3 text-sm leading-7 text-slate-700">{style.raw['Secondary Colors']}</p>
    </div>
    <div class="rounded-[1.5rem] bg-slate-950 p-5 text-white md:col-span-2">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Effects & Animation</p>
      <p class="mt-3 text-sm leading-7 text-slate-200">{style.raw['Effects & Animation']}</p>
    </div>
  </div>
</section>
