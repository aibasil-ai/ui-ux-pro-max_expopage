---
import type { StyleRecord } from '../../../lib/content/get-styles';
interface Props { style: StyleRecord; }
const { style } = Astro.props;
---
<section class="rounded-[2rem] border border-slate-200 bg-white/95 p-6 shadow-sm shadow-slate-950/5">
  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Tokens & Tech</p>
  <h2 class="mt-3 text-2xl font-semibold text-slate-950">實作提示</h2>
  <div class="mt-5 grid gap-4 md:grid-cols-2">
    <div class="rounded-[1.5rem] bg-slate-50 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">CSS / Technical Keywords</p>
      <p class="mt-3 text-sm leading-7 text-slate-700">{style.raw['CSS/Technical Keywords']}</p>
    </div>
    <div class="rounded-[1.5rem] bg-slate-50 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Design System Variables</p>
      <p class="mt-3 text-sm leading-7 text-slate-700">{style.raw['Design System Variables']}</p>
    </div>
  </div>
  <div class="mt-4 rounded-[1.5rem] border border-dashed border-slate-300 p-5 text-sm leading-7 text-slate-600">
    {style.raw['Implementation Checklist']}
  </div>
</section>
