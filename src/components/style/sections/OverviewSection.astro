---
import type { StyleRecord } from '../../../lib/content/get-styles';
interface Props { style: StyleRecord; }
const { style } = Astro.props;
---
<section class="rounded-[2rem] border border-slate-200 bg-white/95 p-6 shadow-sm shadow-slate-950/5">
  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Overview</p>
  <h2 class="mt-3 text-2xl font-semibold text-slate-950">風格摘要</h2>
  <p class="mt-4 text-sm leading-7 text-slate-600">{style.summary}</p>
  <div class="mt-5 grid gap-4 md:grid-cols-3">
    <div class="rounded-[1.5rem] bg-slate-50 p-4"><p class="text-xs text-slate-500">Origin</p><p class="mt-2 text-sm font-semibold text-slate-900">{style.raw['Era/Origin']}</p></div>
    <div class="rounded-[1.5rem] bg-slate-50 p-4"><p class="text-xs text-slate-500">Framework Fit</p><p class="mt-2 text-sm font-semibold text-slate-900">{style.raw['Framework Compatibility']}</p></div>
    <div class="rounded-[1.5rem] bg-slate-50 p-4"><p class="text-xs text-slate-500">Mobile Friendly</p><p class="mt-2 text-sm font-semibold text-slate-900">{style.raw['Mobile-Friendly']}</p></div>
  </div>
</section>
