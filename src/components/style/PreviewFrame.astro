---
interface Props {
  title: string;
  accentMode: string;
}

const { title, accentMode } = Astro.props;
const accentClasses: Record<string, string> = {
  indigo: 'from-indigo-500/20 via-white to-indigo-100',
  cyan: 'from-cyan-500/20 via-white to-cyan-100',
  emerald: 'from-emerald-500/20 via-white to-emerald-100',
  fuchsia: 'from-fuchsia-500/20 via-white to-fuchsia-100',
  amber: 'from-amber-500/20 via-white to-amber-100',
  mono: 'from-slate-500/10 via-white to-slate-100',
  crimson: 'from-rose-500/20 via-white to-rose-100'
};
---

<div class={`overflow-hidden rounded-[2rem] border border-slate-200 bg-gradient-to-br ${accentClasses[accentMode] ?? accentClasses.indigo} shadow-sm shadow-slate-950/5`}>
  <div class="flex items-center justify-between border-b border-slate-200/70 bg-white/75 px-5 py-3 backdrop-blur">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Live Preview</p>
    <p class="text-sm font-medium text-slate-600">{title}</p>
  </div>
  <div class="p-6">
    <slot />
  </div>
</div>
