---
import PreviewFrame from '../PreviewFrame.astro';
import type { StyleRecord } from '../../../lib/content/get-styles';

interface Props {
  style: StyleRecord;
  accentMode: string;
}

const { style, accentMode } = Astro.props;
---

<PreviewFrame title={`${style.title} / Dashboard`} accentMode={accentMode}>
  <div class="grid gap-4 xl:grid-cols-[0.82fr_1.18fr]">
    <aside class="rounded-[1.5rem] border border-white/50 bg-white/80 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Signals</p>
      <div class="mt-4 space-y-3">
        <div class="rounded-2xl bg-slate-950 p-4 text-white">
          <p class="text-xs text-slate-400">Revenue</p>
          <p class="mt-2 text-2xl font-semibold">$128.4k</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-4">
          <p class="text-xs text-slate-500">Trend</p>
          <p class="mt-2 text-base font-semibold text-slate-900">{style.title}</p>
        </div>
      </div>
    </aside>
    <div class="grid gap-4">
      <div class="rounded-[1.5rem] border border-white/50 bg-white/80 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Primary Chart</p>
        <div class="mt-4 grid h-32 grid-cols-8 items-end gap-2">
          {[34, 58, 42, 76, 61, 88, 64, 92].map((value, index) => (
            <div class="rounded-t-xl bg-slate-950/80" style={`height:${value}%`} key={index}></div>
          ))}
        </div>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="rounded-[1.5rem] border border-white/50 bg-white/75 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Density</p>
          <p class="mt-3 text-sm leading-7 text-slate-700">{style.raw['Best For']}</p>
        </div>
        <div class="rounded-[1.5rem] border border-white/50 bg-white/75 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Motion</p>
          <p class="mt-3 text-sm leading-7 text-slate-700">{style.raw['Effects & Animation']}</p>
        </div>
      </div>
    </div>
  </div>
</PreviewFrame>
