---
import PreviewFrame from '../PreviewFrame.astro';
import type { StyleRecord } from '../../../lib/content/get-styles';

interface Props {
  style: StyleRecord;
  accentMode: string;
}

const { style, accentMode } = Astro.props;
---

<PreviewFrame title={`${style.title} / Landing`} accentMode={accentMode}>
  <div class="space-y-4">
    <div class="grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-[1.75rem] border border-white/50 bg-white/75 p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Hero</p>
        <h3 class="mt-3 text-3xl font-semibold text-slate-950">Launch a landing page in {style.title}</h3>
        <p class="mt-3 max-w-xl text-sm leading-7 text-slate-600">{style.raw['AI Prompt Keywords']}</p>
        <div class="mt-5 inline-flex rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white">Primary CTA</div>
      </div>
      <div class="rounded-[1.75rem] border border-slate-200 bg-slate-950 p-6 text-white">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Conversion Focus</p>
        <p class="mt-3 text-sm leading-7 text-slate-200">{style.raw['Conversion-Focused']}</p>
        <p class="mt-4 text-sm leading-7 text-slate-300">{style.raw['Best For']}</p>
      </div>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      <div class="rounded-[1.5rem] border border-white/50 bg-white/75 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Section 01</p>
        <p class="mt-3 text-sm leading-7 text-slate-700">Narrative hook</p>
      </div>
      <div class="rounded-[1.5rem] border border-white/50 bg-white/75 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Section 02</p>
        <p class="mt-3 text-sm leading-7 text-slate-700">Benefits & proof</p>
      </div>
      <div class="rounded-[1.5rem] border border-white/50 bg-white/75 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Section 03</p>
        <p class="mt-3 text-sm leading-7 text-slate-700">Conversion CTA</p>
      </div>
    </div>
  </div>
</PreviewFrame>
