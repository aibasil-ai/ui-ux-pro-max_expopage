---
import type { ChartRecord } from '../../lib/content/get-charts';

interface Props {
  chart: ChartRecord;
}

const { chart } = Astro.props;
const values = [22, 35, 48, 39, 61, 54, 72, 66];
---

<div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm shadow-slate-950/5">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{chart.title}</p>
  <h2 class="mt-4 text-3xl font-semibold text-slate-950">{chart.raw['Data Type']}</h2>
  <p class="mt-3 text-sm leading-7 text-slate-600">{chart.summary}</p>
  <div class="mt-6 grid h-40 grid-cols-8 items-end gap-2">
    {values.map((value, index) => (
      <div class="rounded-t-xl bg-slate-950/80" style={`height:${value}%`} key={index}></div>
    ))}
  </div>
</div>
