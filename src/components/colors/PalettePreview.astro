---
import type { ColorRecord } from '../../lib/content/get-colors';

interface Props {
  palette: ColorRecord;
}

const { palette } = Astro.props;
const colors = palette.palette || {
  primary: palette.raw['Primary (Hex)'],
  secondary: palette.raw['Secondary (Hex)'],
  cta: palette.raw['CTA (Hex)'],
  background: palette.raw['Background (Hex)'],
  text: palette.raw['Text (Hex)'],
  border: palette.raw['Border (Hex)']
};
---

<div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm shadow-slate-950/5">
  <div class="grid min-h-[240px] grid-cols-[1.15fr_0.85fr]" style={`background:${colors.background}; color:${colors.text};`}>
    <div class="p-6">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] opacity-60">{palette.title}</p>
      <h2 class="mt-4 text-3xl font-semibold">Palette Preview</h2>
      <p class="mt-4 text-sm leading-7 opacity-80">{palette.summary}</p>
      <div class="mt-6 inline-flex rounded-full px-4 py-2 text-sm font-semibold text-white" style={`background:${colors.cta};`}>
        Primary CTA
      </div>
    </div>
    <div class="border-l border-black/5 p-6">
      <div class="grid gap-3">
        <div class="rounded-2xl p-4 text-white" style={`background:${colors.primary};`}>
          <p class="text-xs opacity-80">Primary</p>
          <p class="mt-2 font-semibold">{colors.primary}</p>
        </div>
        <div class="rounded-2xl p-4 text-white" style={`background:${colors.secondary};`}>
          <p class="text-xs opacity-80">Secondary</p>
          <p class="mt-2 font-semibold">{colors.secondary}</p>
        </div>
      </div>
    </div>
  </div>
</div>
