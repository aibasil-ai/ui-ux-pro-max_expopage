---
interface Props {
  goodLabel?: string;
  badLabel?: string;
  goodExample?: string;
  badExample?: string;
}

const {
  goodLabel = '正確示例',
  badLabel = '錯誤示例',
  goodExample = '',
  badExample = ''
} = Astro.props;
---

<div class="grid gap-4 lg:grid-cols-2">
  <section class="rounded-[1.75rem] border border-emerald-200 bg-emerald-50 p-5">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">{goodLabel}</p>
    <pre class="mt-3 whitespace-pre-wrap text-sm leading-7 text-emerald-950">{goodExample}</pre>
  </section>
  <section class="rounded-[1.75rem] border border-rose-200 bg-rose-50 p-5">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-rose-700">{badLabel}</p>
    <pre class="mt-3 whitespace-pre-wrap text-sm leading-7 text-rose-950">{badExample}</pre>
  </section>
</div>
