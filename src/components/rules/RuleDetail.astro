---
import type { GeneratedRecord } from '../../lib/content/load-generated';
import ItemActionBar from '../actions/ItemActionBar.astro';
import BeforeAfterDemo from './BeforeAfterDemo.astro';

interface RuleRecord extends GeneratedRecord {
  platform?: string;
  severity?: string;
}

interface Props {
  rule: RuleRecord;
  mode: 'ux' | 'reasoning' | 'special';
}

const { rule, mode } = Astro.props;
const raw = rule.raw;
const ruleTypeLabel = mode === 'ux' ? 'UX 指南' : mode === 'reasoning' ? '推理規則' : '專門規則';
const href = mode === 'ux' ? `/rules/ux/${rule.slug}` : mode === 'reasoning' ? `/rules/reasoning/${rule.slug}` : `/rules/special/${rule.slug}`;
let decisionRules = '';
if (mode === 'reasoning') {
  try {
    const parsed = JSON.parse(raw['Decision_Rules'] || '{}');
    decisionRules = Object.entries(parsed)
      .map(([key, value]) => `${key}: ${String(value)}`)
      .join('\n');
  } catch {
    decisionRules = raw['Decision_Rules'] || '';
  }
}
---

<article class="space-y-6 rounded-[2rem] border border-slate-200 bg-white/95 p-6 shadow-sm shadow-slate-950/5">
  <div class="flex flex-wrap items-center gap-3">
    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-600">{rule.category}</span>
    {rule.platform && <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">{rule.platform}</span>}
    {rule.severity && <span class="rounded-full bg-slate-950 px-3 py-1 text-xs font-medium text-white">{rule.severity}</span>}
  </div>

  <div>
    <h1 class="text-4xl font-semibold tracking-tight text-slate-950">{rule.title}</h1>
    <p class="mt-4 text-lg leading-8 text-slate-600">{rule.summary}</p>
  </div>

  <ItemActionBar
    id={`${mode}:${rule.slug}`}
    title={rule.title}
    href={href}
    dataset={ruleTypeLabel}
    summary={rule.summary}
    relatedLinks={[{ href: '/rules', label: '回規則中心' }]}
  />

  <div class="grid gap-4 lg:grid-cols-2">
    {raw['Do'] && (
      <section class="rounded-[1.75rem] bg-slate-50 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Do</p>
        <p class="mt-3 text-sm leading-7 text-slate-700">{raw['Do']}</p>
      </section>
    )}
    {raw["Don't"] && (
      <section class="rounded-[1.75rem] bg-slate-50 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Don't</p>
        <p class="mt-3 text-sm leading-7 text-slate-700">{raw["Don't"]}</p>
      </section>
    )}
  </div>

  {mode === 'reasoning' ? (
    <div class="grid gap-4 lg:grid-cols-2">
      <section class="rounded-[1.75rem] bg-slate-50 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Recommended Pattern</p>
        <p class="mt-3 text-sm leading-7 text-slate-700">{raw['Recommended_Pattern']}</p>
      </section>
      <section class="rounded-[1.75rem] bg-slate-50 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Style Priority</p>
        <p class="mt-3 text-sm leading-7 text-slate-700">{raw['Style_Priority']}</p>
      </section>
      <section class="rounded-[1.75rem] bg-slate-950 p-5 text-white lg:col-span-2">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Decision Rules</p>
        <pre class="mt-3 whitespace-pre-wrap text-sm leading-7 text-slate-200">{decisionRules}</pre>
      </section>
    </div>
  ) : (
    <BeforeAfterDemo
      goodExample={raw['Code Example Good'] || raw['Do'] || ''}
      badExample={raw['Code Example Bad'] || raw["Don't"] || ''}
    />
  )}
</article>
