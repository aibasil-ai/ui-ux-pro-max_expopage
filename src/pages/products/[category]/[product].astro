---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RecommendationExplorer from '../../../components/recommendation/RecommendationExplorer';
import { getProducts } from '../../../lib/content/get-products';
import { buildProductTaxonomy } from '../../../lib/product-taxonomy';
import { getRecommendationBundlesForProduct } from '../../../lib/recommendation/get-recommendations';

export async function getStaticPaths() {
  const products = await getProducts();
  const categories = buildProductTaxonomy(products);

  return categories.flatMap((category) =>
    category.products.map((product) => ({
      params: {
        category: category.id,
        product: product.slug
      },
      props: {
        category,
        product
      }
    }))
  );
}

const { category, product } = Astro.props;
const raw = product.raw;
const bundles = await getRecommendationBundlesForProduct(product);
---

<BaseLayout title={`${product.title} · UI UX Pro Max`} description={product.summary}>
  <section class="container-shell py-16 md:py-20">
    <a href="/#product-picker" class="text-sm font-medium text-slate-500 hover:text-slate-900">← 回到產品入口</a>

    <div class="mt-6 grid gap-8 xl:grid-cols-[0.95fr_1.05fr] xl:items-start">
      <div class="space-y-6 xl:sticky xl:top-24">
        <section class="rounded-[2rem] border border-slate-200 bg-white/90 p-8 shadow-sm shadow-slate-950/5">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-indigo-600">{category.name}</p>
          <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950">{product.title}</h1>
          <p class="mt-4 text-lg leading-8 text-slate-600">{product.summary}</p>

          <dl class="mt-8 space-y-5 text-sm text-slate-600">
            <div>
              <dt class="font-semibold text-slate-900">Primary Style Recommendation</dt>
              <dd class="mt-1">{raw['Primary Style Recommendation']}</dd>
            </div>
            <div>
              <dt class="font-semibold text-slate-900">Secondary Styles</dt>
              <dd class="mt-1">{raw['Secondary Styles']}</dd>
            </div>
            <div>
              <dt class="font-semibold text-slate-900">Landing Page Pattern</dt>
              <dd class="mt-1">{raw['Landing Page Pattern']}</dd>
            </div>
            <div>
              <dt class="font-semibold text-slate-900">Dashboard Style</dt>
              <dd class="mt-1">{raw['Dashboard Style (if applicable)']}</dd>
            </div>
            <div>
              <dt class="font-semibold text-slate-900">Color Palette Focus</dt>
              <dd class="mt-1">{raw['Color Palette Focus']}</dd>
            </div>
          </dl>
        </section>

        <section class="rounded-[2rem] border border-slate-200 bg-slate-950 p-8 text-white shadow-sm shadow-slate-950/10">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-indigo-300">推薦邏輯</p>
          <h2 class="mt-4 text-2xl font-semibold">先給完整組合，再讓你自由收斂</h2>
          <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-300">
            <li>• 依產品適配度排序，先顯示最貼近該產品的方向</li>
            <li>• 可切換最佳推薦 / 精選 3 組 / 全部瀏覽</li>
            <li>• 以風格名稱作為主要篩選器</li>
            <li>• 每張卡都提供可直接複製的 Prompt</li>
          </ul>
        </section>
      </div>

      <section class="space-y-6">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Recommendation Explorer</p>
          <h2 class="mt-3 text-3xl font-semibold text-slate-950">最適合 {product.title} 的推薦結果頁</h2>
          <p class="mt-3 text-base leading-7 text-slate-600">
            先看推薦組合，再切換模式或依風格篩選。每一張卡都會把風格、配色、字體、Landing 結構與 Prompt 一次整理給你。
          </p>
        </div>

        <RecommendationExplorer client:load bundles={bundles} />
      </section>
    </div>
  </section>
</BaseLayout>
