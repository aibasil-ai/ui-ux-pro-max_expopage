---
import ItemActionBar from '../../components/actions/ItemActionBar.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getStyles } from '../../lib/content/get-styles';
import { getColors } from '../../lib/content/get-colors';
import { getTypography } from '../../lib/content/get-typography';
import { buildPrompt } from '../../lib/prompt-builder';
import { getStyleManifest } from '../../lib/style-manifests';
import { getStyleBilingualTitle } from '../../lib/style-localization';
import { styleShowcaseRegistry } from '../../components/style/StyleShowcaseRegistry';
import MissingShowcase from '../../components/style/showcases/MissingShowcase.astro';

export async function getStaticPaths() {
  const styles = await getStyles();
  return styles.map((style) => ({
    params: { slug: style.slug },
    props: { style }
  }));
}

const { style } = Astro.props;
const manifest = getStyleManifest(style);
const colors = await getColors();
const typography = await getTypography();
const relatedColor = colors.find((item) => item.title === style.title) ?? colors[0];
const relatedTypography = typography.find((item) => String(item.raw['Mood/Style Keywords'] || '').toLowerCase().includes(style.title.split(' ')[0].toLowerCase())) ?? typography[0];
const pseudoProduct = {
  ...style,
  raw: {
    ...style.raw,
    'Dashboard Style (if applicable)': style.title,
    'Color Palette Focus': style.raw['Primary Colors'],
    'Landing Page Pattern': style.raw['Best For'],
    'Key Considerations': style.summary,
    'Primary Style Recommendation': style.title,
    'Secondary Styles': style.raw['Best For'],
    Keywords: style.raw['Keywords']
  }
};
const previewPrompt = buildPrompt({
  product: pseudoProduct,
  style,
  color: relatedColor,
  typography: relatedTypography,
  landing: null,
  dashboardLabel: style.title,
  reasoning: null
});
const href = `/styles/${style.slug}`;
const localizedStyleTitle = getStyleBilingualTitle(style.slug, style.title);
const localizedStyle = { ...style, title: localizedStyleTitle };
const showcaseModules = import.meta.glob('../../components/style/showcases/*.astro', { eager: true });
const showcasePath = styleShowcaseRegistry[style.slug];
const Showcase =
  (showcasePath && (showcaseModules[showcasePath] as { default: unknown })?.default) ?? MissingShowcase;
---

<BaseLayout title={`${localizedStyleTitle} · Style Showcase`} description={style.summary}>
  <section class="container-shell py-16 md:py-20">
    <a href="/#product-picker" class="text-sm font-medium text-slate-500 hover:text-slate-900">← 回到首頁入口</a>

    <div class="mt-6 space-y-8">
      <ItemActionBar
        id={`styles:${style.slug}`}
        title={localizedStyleTitle}
        href={href}
        dataset="風格"
        summary={style.summary}
        relatedLinks={[
          { href: `/colors/${relatedColor.slug}`, label: '相容配色' },
          { href: `/typography/${relatedTypography.slug}`, label: '相容字體' },
          { href: '/rules', label: '查看規則中心' },
          { href: '/rules/ux', label: '看 UX 指南' }
        ]}
      />

      <Showcase
        style={localizedStyle}
        manifest={manifest}
        relatedColor={relatedColor}
        relatedTypography={relatedTypography}
        previewPrompt={previewPrompt}
      />
    </div>
  </section>
</BaseLayout>
