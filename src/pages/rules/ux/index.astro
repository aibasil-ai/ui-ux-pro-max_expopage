---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/navigation/Breadcrumbs.astro';
import { getUxGuidelines } from '../../../lib/content/get-rules';

const rules = await getUxGuidelines();
---

<BaseLayout title="UX 指南 · 規則中心" description="99 條 UX 指南與錯誤示例。">
  <section class="container-shell space-y-8 py-16 md:py-20">
    <Breadcrumbs items={[{ label: '首頁', href: '/' }, { label: '規則中心', href: '/rules' }, { label: 'UX 指南' }]} />
    <h1 class="text-5xl font-semibold tracking-tight text-slate-950">99 條 UX 指南</h1>
    <div class="grid gap-4 lg:grid-cols-2">
      {rules.map((rule) => (
        <a href={`/rules/ux/${rule.slug}`} class="rounded-[1.75rem] border border-slate-200 bg-white/95 p-5 shadow-sm shadow-slate-950/5">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{rule.category}</p>
          <h2 class="mt-3 text-2xl font-semibold text-slate-950">{rule.title}</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">{rule.summary}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
