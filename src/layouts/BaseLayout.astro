---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CompareDrawer from '../components/compare/CompareDrawer';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '從產品類型出發，探索 UI/UX 風格與 Prompt 組合。' } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(79,70,229,0.12),_transparent_35%),linear-gradient(180deg,_#ffffff_0%,_#f8fafc_100%)]">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
      <CompareDrawer client:load />
    </div>
  </body>
</html>
